@using OrganizerBlazorApp.Domain.Entities
@using OrganizerBlazorApp.Domain.Enums

@namespace OrganizerBlazorApp.Components.UI

@if(Unit != null)
{
  <div class="container">
    <div class="mb-4">
      <div class="d-flex justify-content-between align-items-start">
        <h3>@Unit.Title</h3>
        <span class="badge @(Unit.Status == ProcessStatus.Completed ? "bg-success" : "bg-primary")">
          @Unit.Status
        </span>
      </div>
      <p class="text-muted">
        <i class="bi bi-clock"></i> Deadline: @Unit.Deadline.ToString("f")
      </p>
    </div>

    @if (!string.IsNullOrEmpty(Unit.Description))
    {
      <div class="mb-4">
        <h6>Description</h6>
        <p class="border-start ps-3 py-1 bg-light">@Unit.Description</p>
      </div>
    }
    <div class="mb-4">
      @if (_selectedMedia != null)
      {
        <div class="media-preview-area mb-4 p-2 border rounded bg-black d-flex justify-content-center align-items-center" style="min-height: 300px;">
          @if (IsImage(_selectedMedia.Extension))
          {
            <img src="@_selectedMedia.FilePath" class="img-fluid rounded" style="aspect-ratio: 16/9; object-fit: contain;" />
          }
          else if (IsVideo(_selectedMedia.Extension))
          {
            <video controls class="w-100 rounded" style="max-height: 400px;">
              <source src="@_selectedMedia.FilePath" type="video/mp4">
            </video>
          }
          else
          {
            <div class="text-white text-center">
              <i class="bi bi-file-earmark-text fs-1"></i>
              <p>@_selectedMedia.FileName</p>
              <a href="@_selectedMedia.FilePath" target="_blank" class="btn btn-outline-light">Open</a>
            </div>
          }
        </div>
      }
      <label>Multimedia & Attachments</label>
        <MediaGallery Attachments="Unit.Attachments.ToList()" OnMediaSelected="media => _selectedMedia = media" />
    </div>

    @if (Unit.SubTasks.Any())
    {
      <div class="mb-4">
        <h6>Subtasks (@Unit.SubTasks.Count(s => s.Status == ProcessStatus.Completed)/@Unit.SubTasks.Count)</h6>
        <div class="list-group">
          @foreach (var sub in Unit.SubTasks)
          {
            <div class="list-group-item d-flex align-items-center">
              <i class="bi @(sub.Status == ProcessStatus.Completed ? "bi-check-circle-fill text-success" : "bi-circle text-muted") me-2"></i>
              <span class="@(sub.Status == ProcessStatus.Completed ? "text-decoration-line-through" : "")">@sub.Title</span>
            </div>
          }
        </div>
      </div>
    }
  </div>
}

@code {
  [Parameter] public TodoUnit? Unit { get; set; } = null!;
  [Parameter] public EventCallback OnEditRequested { get; set; }
  private Attachment? _selectedMedia;

  protected override void OnInitialized()
  {
    _selectedMedia = Unit.Attachments.FirstOrDefault();
  }
  
  private bool IsImage(string ext) => new[] { ".jpg", ".jpeg", ".png", ".webp" }.Contains(ext.ToLower());
  private bool IsVideo(string ext) => new[] { ".mp4" }.Contains(ext.ToLower());
}