@page "/"
@using OrganizerBlazorApp.Application.Services
@using OrganizerBlazorApp.Domain.Entities
@using OrganizerBlazorApp.Domain.Interfaces
@rendermode InteractiveServer
@inject TaskService TaskService
@inject ITaskRepository Repository

<PageTitle>Organizer Dashboard</PageTitle>
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Business Tasks</h1>
        <button class="btn btn-primary" @onclick="AddSampleTask">
            + Seed Sample Task
        </button>
    </div>

    @if (units == null)
    {
        <p><em>Loading units...</em></p>
    }
    else if (!units.Any())
    {
        <div class="alert alert-info">
            No units found. Click the button above to add a sample task!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var task in units.Where(t => t.ParentUnitId == null))
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@task.Title</h5>
                            <h6 class="card-subtitle mb-2 text-muted">
                                Deadline: @task.Deadline.ToString("MMM dd, yyyy")
                            </h6>
                            <p class="card-text">@task.Description</p>
                            
                            @if (task.SubTasks.Any())
                            {
                                <div class="mt-3">
                                    <strong>Subtasks:</strong>
                                    <ul class="list-group list-group-flush">
                                        @foreach (var sub in task.SubTasks)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                @sub.Title
                                                <span class="badge @(sub.IsRequired ? "bg-danger" : "bg-secondary")">
                                                    @(sub.IsRequired ? "Required" : "Optional")
                                                </span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IEnumerable<TodoUnit>? units;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        units = await Repository.GetAllAsync();
    }

    private async Task AddSampleTask()
    {
        await TaskService.SeedSampleTaskAsync();
        await LoadTasks(); // Refresh the list
    }
}