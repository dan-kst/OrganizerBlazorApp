@page "/"
@using OrganizerBlazorApp.Application.Services
@using OrganizerBlazorApp.Domain.Entities
@using OrganizerBlazorApp.Domain.Interfaces
@using OrganizerBlazorApp.Domain.Enums
@using OrganizerBlazorApp.Domain.Extentions
@using OrganizerBlazorApp.Components.UI
@rendermode InteractiveServer
@inject TaskService TaskService
@inject ITaskRepository Repository

<PageTitle>Organizer Dashboard</PageTitle>
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Business Tasks</h1>
        <button class="btn btn-primary" @onclick="AddSampleTask">
            + Seed Sample Task
        </button>
    </div>

  @if (units == null)
  {
    <p><em>Loading units...</em></p>
  }
  else if (!units.Any())
  {
    <div class="alert alert-info">
      No units found. Click the button above to add a sample unit!
    </div>
  }
  else
  {
    <div class="row row-cols-1 row-cols-md-2 g-4">
      @foreach (var unit in units.Where(t => t.ParentUnitId == null))
      {
        <UnitCard Unit="unit" OnDeleteClick="DeleteTask" OnStatusToggle="ToggleStatus"></UnitCard>
      }
    </div>
  }
</div>

@code {
    private IEnumerable<TodoUnit>? units;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        units = await Repository.GetAllAsync();
    }

  private async Task AddSampleTask()
  {
    await TaskService.SeedSampleTaskAsync();
    // Refresh the list
    await LoadTasks();
  }

  // Unit Card delegates
  private async Task ToggleStatus(TodoUnit unit)
  {
    await TaskService.ToggleProcessStatusAsync(unit.Id);
    await LoadTasks();
  }

  private async Task DeleteTask(TodoUnit unit)
  {
    await TaskService.DeleteTaskAsync(unit.Id);
    await LoadTasks();
  }
}